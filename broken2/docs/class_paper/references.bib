@article{yang2025shield,
  title   = {SHIELD: Safety on Humanoids via CBFs In Expectation on Learned Dynamics},
  author  = {Yang, Lizhi and Werner, Blake and Cosner, Ryan K. and Fridovich-Keil, David and Culbertson, Preston and Ames, Aaron D.},
  journal = {arXiv preprint arXiv:2505.11494},
  year    = {2025},
  note    = {Closest published related work: humanoid CBF safety filter with onboard LiDAR. Verified 2026-05-08 against arXiv:2505.11494 Section V: Livox Mid-360 LiDAR -> Euclidean clustering of pointcloud -> each cluster modeled as a cylinder with FIXED radius R=0.3m (NOT per-cluster radius fitting) -> analytical min-SDF (Eq. 19) with exp smoothing. Same exp-smoothed form as ours. Differentiation: (1) their alpha is per-episode risk-calibrated via Freedman / Brent's method, ours is per-step RL-learned with multi-param robust QP; (2) their cylinder radius is fixed across all clusters, ours varies per obstacle in DR (0.10-0.50m); (3) we add 4 robust slacks (alpha/phi/a/c) tied to literature uncertainty classes, they use alpha + lambda + gamma as fixed hyperparams.}
